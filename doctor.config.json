{
  "$schema": "https://react.doctor/schema/config.json",
  "ignore": {
    "files": ["**/.agents/**", "**/.output/**"],
    "overrides": [
      {
        "files": ["apps/mobile/lib/theme.ts", "lib/theme.ts"],
        "rules": ["deslop/unused-export"]
      },
      {
        "files": [
          "components/ui/**",
          "apps/mobile/components/ui/**",
          "packages/ui/src/components/**",
          "src/components/badge.tsx",
          "src/components/button-group.tsx",
          "src/components/button.tsx",
          "src/components/carousel.tsx",
          "src/components/collapsible.tsx",
          "src/components/hover-card.tsx",
          "src/components/input-group.tsx",
          "src/components/input-otp.tsx",
          "src/components/native-select.tsx",
          "src/components/navigation-menu.tsx",
          "src/components/resizable.tsx",
          "src/components/tabs.tsx",
          "src/components/toggle.tsx"
        ],
        "rules": [
          "deslop/unused-file",
          "react-doctor/no-multi-comp",
          "react-doctor/no-pass-data-to-parent",
          "react-doctor/no-prop-callback-in-effect",
          "react-doctor/only-export-components"
        ]
      },
      {
        "files": [
          "apps/web/src/lib/suno-studio.tsx",
          "apps/web/src/routes/albums/$folder.tsx",
          "apps/web/src/routes/inspirations.tsx",
          "src/lib/suno-studio.tsx",
          "src/routes/albums/$folder.tsx",
          "src/routes/inspirations.tsx"
        ],
        "rules": [
          "react-doctor/no-multi-comp",
          "react-doctor/only-export-components",
          "react-doctor/prefer-useReducer"
        ]
      },
      {
        "files": ["packages/workflow/package.json", "package.json"],
        "rules": ["deslop/unused-dependency"]
      },
      {
        "files": [
          "packages/workflow/src/remotion-cover-title.tsx",
          "packages/workflow/src/remotion-youtube-video.tsx",
          "src/remotion-cover-title.tsx",
          "src/remotion-youtube-video.tsx"
        ],
        "rules": ["react-doctor/only-export-components"]
      }
    ]
  }
}
